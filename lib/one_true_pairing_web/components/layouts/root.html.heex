<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Phoenix Framework">
      <%= assigns[:page_title] || "OneTruePairing" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="mac-body antialiased">
    <!-- Classic Mac OS menu bar -->
    <div class="mac-menubar">
      <span id="menu-apple" class="mac-menubar-title">&#63743;</span>
      <a href="/"><span class="mac-menubar-item unused">File</span></a>
      <a href="/"><span class="mac-menubar-item unused">Edit</span></a>
      <a href="/"><span class="mac-menubar-item unused">View</span></a>

      <a href="https://github.com/tjarratt/one-true-pairing" target="_blank">
        <span class="mac-menubar-item">Special</span>
      </a>
      <a
        href="https://teams.microsoft.com/l/chat/19:5dfa3cb5-a68c-40b0-b9b0-c9130877f809_d7782798-8641-48b2-ac2f-5eabb7fe9326@unq.gbl.spaces/conversations?context=%7B%22contextType%22%3A%22chat%22%7D"
        target="_blank"
      >
        <span class="mac-menubar-item">Help</span>
      </a>
    </div>

    <div id="mac-menubar-popup" class="hidden mac-window" role="dialog">
      <div class="mac-titlebar">
        <button id="mac-popup-close" class="mac-close-box" />
      </div>
      <div class="mac-window-body">
        <div class="mac-popup-title">it's always april 1st somewhere ...</div>
        <div class="mac-popup-hotdogs">🌭🌭🌭</div>
        <div class="mac-popup-condiments">🍅💛🍅</div>
      </div>
    </div>

    <%= @inner_content %>
  </body>
</html>
